{
  "skill_name": "companion-billing",
  "version": "1.0.0",
  "description": "心跳回忆支付与订阅管理系统",
  "author": "Windsurf",
  "enabled": true,
  "dependencies": [],
  "permissions": ["file_system_read", "file_system_write", "external_api"],
  "triggers": {
    "commands": [
      {
        "command": "/bill",
        "description": "查看账单状态和余额",
        "handler": "handleTelegramCommand"
      },
      {
        "command": "/topup",
        "description": "充值金币",
        "handler": "handleTelegramCommand"
      },
      {
        "command": "/subscribe",
        "description": "订阅管理和升级",
        "handler": "handleTelegramCommand"
      }
    ],
    "callbacks": [
      {
        "pattern": "action_*",
        "description": "处理账单相关动作回调查询",
        "handler": "handleTelegramCallback"
      },
      {
        "pattern": "topup_*",
        "description": "处理充值回调查询",
        "handler": "handleTelegramCallback"
      },
      {
        "pattern": "subscribe_*",
        "description": "处理订阅回调查询",
        "handler": "handleTelegramCallback"
      },
      {
        "pattern": "gift_*",
        "description": "处理礼物购买回调查询",
        "handler": "handleTelegramCallback"
      },
      {
        "pattern": "pay_*",
        "description": "处理支付回调查询",
        "handler": "handleTelegramCallback"
      }
    ],
    "middleware": [
      {
        "event": "before_message",
        "description": "检查消息发送权限",
        "handler": "checkPermission",
        "params": {"action": "message"}
      },
      {
        "event": "before_voice",
        "description": "检查语音发送权限",
        "handler": "checkPermission",
        "params": {"action": "voice"}
      },
      {
        "event": "before_photo",
        "description": "检查照片发送权限",
        "handler": "checkPermission",
        "params": {"action": "photo"}
      },
      {
        "event": "before_companion_create",
        "description": "检查伴侣创建权限",
        "handler": "checkPermission",
        "params": {"action": "companion"}
      }
    ],
    "scheduled_tasks": [
      {
        "schedule": "0 0 * * *",
        "description": "每日重置使用量限制",
        "handler": "resetDailyUsage"
      },
      {
        "schedule": "0 */6 * * *",
        "description": "清理过期支付记录",
        "handler": "cleanupExpiredPayments"
      },
      {
        "schedule": "0 9 * * *",
        "description": "检查订阅到期状态",
        "handler": "checkSubscriptionExpiry"
      }
    ]
  },
  "api_endpoints": [
    {
      "path": "/billing/status",
      "method": "GET",
      "description": "获取用户账单状态",
      "handler": "getUserBillingStatus",
      "auth_required": true
    },
    {
      "path": "/billing/subscribe",
      "method": "POST",
      "description": "处理订阅升级",
      "handler": "processPayment",
      "auth_required": true
    },
    {
      "path": "/billing/topup",
      "method": "POST",
      "description": "处理金币充值",
      "handler": "processPayment",
      "auth_required": true
    },
    {
      "path": "/billing/gifts",
      "method": "GET",
      "description": "获取礼物目录",
      "handler": "getGiftCatalog",
      "auth_required": true
    },
    {
      "path": "/billing/gifts/purchase",
      "method": "POST",
      "description": "购买礼物",
      "handler": "purchaseGift",
      "auth_required": true
    },
    {
      "path": "/billing/admin/payments/pending",
      "method": "GET",
      "description": "管理员获取待确认支付",
      "handler": "getPendingPayments",
      "auth_required": true,
      "admin_required": true
    },
    {
      "path": "/billing/admin/payments/confirm",
      "method": "POST",
      "description": "管理员确认手动支付",
      "handler": "confirmManualPayment",
      "auth_required": true,
      "admin_required": true
    }
  ],
  "configuration": {
    "data_directory": "credentials",
    "billing_file": "user_billing.json",
    "gift_catalog_file": "gift-catalog.json",
    "test_mode": true,
    "supported_payment_methods": ["test_key", "manual_confirm"],
    "subscription_tiers": {
      "free": {
        "name": "免费版",
        "price": 0,
        "daily_messages": 20,
        "daily_voice": 0,
        "daily_photos": 0,
        "max_companions": 1
      },
      "heartbeat": {
        "name": "Heartbeat",
        "price": 9.9,
        "daily_messages": -1,
        "daily_voice": 10,
        "daily_photos": 3,
        "max_companions": 3
      },
      "true_love": {
        "name": "True Love",
        "price": 24.9,
        "daily_messages": -1,
        "daily_voice": -1,
        "daily_photos": -1,
        "max_companions": 10
      }
    }
  },
  "webhooks": [
    {
      "event": "payment_completed",
      "description": "支付完成事件",
      "handler": "handlePaymentCompleted"
    },
    {
      "event": "subscription_upgraded",
      "description": "订阅升级事件",
      "handler": "handleSubscriptionUpgraded"
    },
    {
      "event": "gift_purchased",
      "description": "礼物购买事件",
      "handler": "handleGiftPurchased"
    }
  ]
}
