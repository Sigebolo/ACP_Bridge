# AAQ Environment Configuration
# Copy this file to .env and adjust values for your environment

# ========== Backend ==========
AAQ_HOST=0.0.0.0
AAQ_PORT=8001
AAQ_LOG_LEVEL=INFO
AAQ_WORKERS=4

# ========== Frontend ==========
VITE_API_BASE_URL=http://localhost:8001
VITE_DEV_PORT=5173

# ========== Data ==========
AAQ_DATA_DIR=data
AAQ_LOG_DIR=logs
AAQ_LOG_RETENTION_DAYS=30

# ========== Risk Params ==========
AAQ_MAX_POSITION_PCT=0.20
AAQ_SAFETY_BUFFER_PRICE=100.0
AAQ_STOP_LOSS=0.05
AAQ_TAKE_PROFIT=0.15

# ========== Strategy ==========
AAQ_DOUBLE_LOW_THRESHOLD=130
AAQ_LOOKBACK_PERIOD=20
AAQ_SIGNAL_THRESHOLD=2.0
AAQ_VOLUME_MULTIPLIER=1.2
