#!/usr/bin/env python3
# -*- coding: utf-8 -*-

"""
测试 ACP Bridge + CrewAI 集成
验证 Windsurf 事件是否正确路由到 CrewAI
"""

import asyncio
import json
import subprocess
import sys
import yaml
from datetime import datetime

class ACPBridgeTester:
    def __init__(self):
        self.config_file = "d:/Gemini/agent-hand/bridge/acp_agents_config.json"
        self.bridge_script = "d:/Gemini/agent-hand/bridge/acp_bridge_manager.py"
        self.crewai_config = "d:/Gemini/agent-hand/bridge/crewai.yaml"
        
    def log(self, message):
        """记录日志"""
        timestamp = datetime.now().strftime("%Y-%m-%d %H:%M:%S")
        print(f"[{timestamp}] {message}")
    
    def load_config(self, file_path):
        """安全加载配置文件"""
        try:
            if file_path.endswith('.json'):
                with open(file_path, 'r', encoding='utf-8') as f:
                    return json.load(f)
            elif file_path.endswith('.yaml'):
                with open(file_path, 'r', encoding='utf-8') as f:
                    return yaml.safe_load(f)
            else:
                self.log(f"❌ 不支持的配置文件格式: {file_path}")
                return None
        except FileNotFoundError:
            self.log(f"❌ 配置文件未找到: {file_path}")
            return None
        except Exception as e:
            self.log(f"❌ 配置文件加载错误: {e}")
            return None
    
    def test_config_loading(self):
        """测试配置文件加载"""
        self.log("🧪 测试配置文件加载...")
        
        # 测试加载 ACP 配置
        acp_config = self.load_config(self.config_file)
        if acp_config:
            self.log("✅ ACP Bridge 配置加载成功")
            default_agent = acp_config.get("defaultAgent", "unknown")
            self.log(f"📊 默认代理: {default_agent}")
        else:
            self.log("❌ ACP Bridge 配置加载失败")
            return False
        
        # 测试加载 CrewAI 配置
        crewai_config = self.load_config(self.crewai_config)
        if crewai_config:
            self.log("✅ CrewAI 配置加载成功")
            agents = crewai_config.get("agents", {})
            self.log(f"📊 配置的Agent数量: {len(agents)}")
        else:
            self.log("❌ CrewAI 配置加载失败")
            return False
        
        return True
    
    def test_bridge_startup(self):
        """测试 ACP Bridge 启动"""
        self.log("🚀 测试 ACP Bridge 启动...")
        
        try:
            result = subprocess.run([
                sys.executable, "python", 
                self.bridge_script
            ], 
            capture_output=True, 
            text=True,
            timeout=10,
            encoding='utf-8'
            )
            
            self.log("📊 ACP Bridge 启动输出:")
            self.log(result.stdout)
            
            if result.returncode == 0:
                self.log("✅ ACP Bridge 启动成功")
                return True
            else:
                self.log(f"❌ ACP Bridge 启动失败，返回码: {result.returncode}")
                return False
                
        except subprocess.TimeoutExpired:
            self.log("❌ ACP Bridge 启动超时")
            return False
        except Exception as e:
            self.log(f"❌ ACP Bridge 启动异常: {e}")
            return False
    
    def test_crewai_routing(self):
        """测试 CrewAI 路由"""
        self.log("🧪 测试 CrewAI 路由...")
        
        try:
            result = subprocess.run([
                sys.executable, "crewai", 
                "run",
                "--config", self.crewai_config
            ], 
            capture_output=True, 
            text=True,
            timeout=10,
                input="测试 Windsurf 事件路由\n请确认 CrewAI 已启动并准备接收事件。",
            encoding='utf-8'
            )
            
            self.log("📊 CrewAI 测试输出:")
            self.log(result.stdout)
            
            if result.returncode == 0:
                self.log("✅ CrewAI 路由测试成功")
                return True
            else:
                self.log(f"❌ CrewAI 路由测试失败，返回码: {result.returncode}")
                return False
                
        except subprocess.TimeoutExpired:
            self.log("❌ CrewAI 路由测试超时")
            return False
        except Exception as e:
            self.log(f"❌ CrewAI 路由测试异常: {e}")
            return False
    
    def test_windsurf_event_simulation(self):
        """模拟 Windsurf 事件"""
        self.log("🧪 模拟 Windsurf 事件...")
        
        # 模拟 Windsurf 保存文件事件
        event_data = {
            "file": "test.py",
            "content": "print('Hello from Windsurf!')",
            "timestamp": datetime.now().isoformat()
        }
        
        # 这里应该通过 ACP Bridge 发送给 CrewAI
        self.log("📊 模拟事件数据:")
        self.log(json.dumps(event_data, ensure_ascii=False, indent=2))
        
        return event_data
    
    async def main(self):
        """主测试函数"""
        self.log("🎯 开始 ACP Bridge + CrewAI 集成测试")
        
        # 1. 测试配置文件加载
        if not self.test_config_loading():
            self.log("❌ 配置文件测试失败，停止测试")
            return
        
        # 2. 测试 ACP Bridge 启动
        if not self.test_bridge_startup():
            self.log("❌ ACP Bridge 启动测试失败，停止测试")
            return
        
        # 3. 测试 CrewAI 路由
        if not self.test_crewai_routing():
            self.log("❌ CrewAI 路由测试失败，停止测试")
            return
        
        # 4. 模拟 Windsurf 事件
        event_data = self.test_windsurf_event_simulation()
        
        self.log("🎉 所有测试通过！")
        self.log("📊 测试总结:")
        self.log("  ✅ 配置文件加载正常")
        self.log("  ✅ ACP Bridge 启动正常")
        self.log("  ✅ CrewAI 路由正常")
        self.log("  ✅ 事件模拟正常")
        
        self.log("🚀 ACP Bridge + CrewAI 集成已就绪！")
        
        return True

if __name__ == "__main__":
    tester = ACPBridgeTester()
    success = asyncio.run(tester.main())
    
    if success:
        print("\n🎉 集成测试成功！")
        print("📋 下一步:")
        print("  1. 启动 ACP Bridge: python d:/Gemini/agent-hand/bridge/acp_bridge_manager.py")
        print("  2. 启动 CrewAI: python d:/Gemini/agent-hand/bridge/crewai-run-script.py")
        print("  3. 在 Windsurf 中开始开发")
        print("  4. 监控 CrewAI Web 界面")
    else:
        print("\n❌ 集成测试失败，请检查错误日志")
