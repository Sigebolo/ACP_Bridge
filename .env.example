# Server Configuration
PORT=3000
WS_PORT=3001
HOST=localhost
NODE_ENV=development

# Database Configuration
DATA_PATH=./data
ARTIFACTS_PATH=./artifacts
BACKUP_ENABLED=true
BACKUP_INTERVAL=1h

# Notification Configuration
MAX_NOTIFICATIONS=10000
CLEANUP_INTERVAL=24h
DEFAULT_RETENTION=30d
BROADCAST_TIMEOUT=5000

# Platform Configuration
GOOGLE_CLI_ENABLED=true
GOOGLE_CLI_TIMEOUT=300000
GOOGLE_CLI_MAX_CONCURRENT_TASKS=5
GOOGLE_CLI_DEFAULT_REGION=us-central1

WINDSURF_ENABLED=true
WINDSURF_TIMEOUT=600000
WINDSURF_MAX_CONCURRENT_TASKS=3
WINDSURF_DEFAULT_ENDPOINT=http://localhost:8080

# Security Configuration
API_KEY_REQUIRED=false
RATE_LIMITING_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Upload Configuration
MAX_FILE_SIZE=50MB
ALLOWED_FILE_TYPES=text/*,application/json,application/xml

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=./logs/bridge.log
LOG_MAX_SIZE=10MB
LOG_MAX_FILES=5

# Google Cloud Configuration (if using Google CLI)
# GOOGLE_APPLICATION_CREDENTIALS=./config/google-credentials.json
# GOOGLE_PROJECT_ID=your-project-id
# GOOGLE_REGION=us-central1

# Windsurf Configuration (if using Windsurf)
# WINDSURF_API_KEY=your-windsurf-api-key
WINDSURF_API_ENDPOINT=http://localhost:8080
